{
  "expo": {
    "name": "Stocka",
    "slug": "Stocka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/stockaLogo.png",
    "scheme": "stocka",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Stocka.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/stockaLogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.Ange.stocka"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/stockaLogo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4dadb81c-5917-45f9-bebc-9079adbda778"
      }
    },
    "owner": "titine",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4dadb81c-5917-45f9-bebc-9079adbda778"
    }
  }
}
